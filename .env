# Database
DATABASE_URL="postgresql://postgres:m@localhost:5432/osb_nails?schema=public"

# JWT
JWT_SECRET="mthnguyen912"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="2592000"

# Cookie
COOKIE_ACCESS_TOKEN_MAX_AGE="86400000"
COOKIE_REFRESH_TOKEN_MAX_AGE="2592000000"
# Set to "true" in production for HTTPS
COOKIE_SECURE="false"

# App
NODE_ENV="development"
PORT=3000

# CORS
CORS_ORIGIN="http://localhost:5173"

# Timezone
TZ=America/Chicago

# Prisma
PRISMA_GENERATE_DATAPROXY="false"
PRISMA_CLIENT_ENGINE_TYPE="library"

# I18n
DEFAULT_LANGUAGE="en"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
